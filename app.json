{
  "expo": {
    "name": "Antiquito",
    "slug": "antiquito",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3EE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.antiquito.app",
      "deploymentTarget": "15.1",
      "infoPlist": {
        "NSCameraUsageDescription": "Antiquito needs camera access to photograph and analyze antique objects."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F3EE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.antiquito.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Antiquito needs camera access to photograph and analyze antique objects."
        }
      ],
      "react-native-iap"
    ]
  }
}
